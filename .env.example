# Copiar a .env y completar con valores reales — nunca commitear .env
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cognion
SECRET_KEY=cambiar-por-un-secreto-seguro
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Adaptador SMTP propio de BC Identidad (ADR-012) — envío de invitaciones
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-responder@cognion.local
